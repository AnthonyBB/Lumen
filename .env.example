# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lumen

# JWT — must be at least 32 characters
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Email (leave blank to use Ethereal auto-account in development)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@lumen-game.com

# DEV ONLY — allow login without email verification. Ignored unless NODE_ENV is
# not "production". Never set this in a deployed/production environment.
DEV_SKIP_EMAIL_VERIFICATION=false
